{
  "expo": {
    "name": "ADLTrack",
    "slug": "adltrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c0a09"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adltrack.app",
      "infoPlist": {
        "NSCameraUsageDescription": "ADLTrack needs camera access to capture task completion photos and incident evidence.",
        "NSPhotoLibraryUsageDescription": "ADLTrack needs photo library access to upload images for task documentation."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0c0a09"
      },
      "package": "com.adltrack.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ADLTrack to access your camera for task photos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow ADLTrack to access your photos for uploading care documentation."
        }
      ]
    ]
  }
}
